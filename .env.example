# --- Mikro-Banka PoC Ortam Değişkenleri (ÖRNEK) ---
# Kopyalayıp .env olarak kaydedin:  cp .env.example .env
# NAS üzerinde port çakışması olursa buradan değiştirin.

# RabbitMQ kimlik bilgileri (kendi güçlü değerlerinizle değiştirin)
RABBITMQ_USER=mikrobank
RABBITMQ_PASS=degistir-beni

# Dışarı açılan portlar (NAS IP'niz üzerinden erişilir)
FRONTEND_PORT=8080     # -> http://NAS_IP:8080  (Dashboard buradan açılır)
GATEWAY_PORT=3000      # -> WebSocket / API  (dolu ise 3100 gibi boş bir port verin)
AI_PORT=8000           # -> AI servisi health/metrics
RABBITMQ_UI_PORT=15672 # -> RabbitMQ yönetim paneli (opsiyonel)
